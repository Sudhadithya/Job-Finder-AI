# ==========================================
# Root Environment Variables Template
# Copy this file to respective subdirectories
# ==========================================

# ------------------------------------------
# Backend Config (Copy to backend/.env)
# ------------------------------------------
# Gemini API Key for Resume Parsing & Matching
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (Alternative AI model, optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL database connection string. If connection fails, system falls back to a local SQLite database (jobfinder.db)
DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5432/jobfinder

# ------------------------------------------
# Frontend Config (Copy to frontend/.env.local)
# ------------------------------------------
# Base API URL pointing to the backend FastAPI server
NEXT_PUBLIC_API_URL=http://localhost:8000

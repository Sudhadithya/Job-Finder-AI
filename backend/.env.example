# Gemini API Key (Required for resume parsing & matching engine)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API Key (Alternative model support, optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database connection URL
# Uses PostgreSQL with pg8000 adapter. Fallbacks automatically to SQLite (jobfinder.db) if unavailable.
DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5432/jobfinder
